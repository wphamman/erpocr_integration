			"fieldname": "vat_amount",
			"fieldtype": "Currency",
			"label": "VAT Amount"
		},
		{
			"fieldname": "currency",
			"fieldtype": "Data",
			"label": "Currency"
		},
		{
			"fieldname": "confidence",
			"fieldtype": "Percent",
			"label": "Confidence",
			"read_only": 1,
			"description": "Gemini extraction confidence score"
		},
		{
			"fieldname": "column_break_header2",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "description",
			"fieldtype": "Small Text",
			"label": "Description",
			"read_only": 1,
			"description": "Full description extracted from slip"
		},
		{
			"fieldname": "source_type",
			"fieldtype": "Data",
			"label": "Source",
			"read_only": 1
		},
		{
			"fieldname": "uploaded_by",
			"fieldtype": "Link",
			"label": "Uploaded By",
			"options": "User",
			"read_only": 1
		},
		{
			"fieldname": "captured_at",
			"fieldtype": "Datetime",
			"label": "Captured At (device)",
			"read_only": 1,
			"description": "Device-truth capture time supplied by the mobile upload client. Distinct from the record creation timestamp — offline-queued uploads may arrive long after capture. Empty for Drive-sourced and Desk-created slips."
		},
		{
			"fieldname": "client_request_id",
			"fieldtype": "Data",
			"label": "Client Request ID",
			"unique": 1,
			"read_only": 1,
			"no_copy": 1,
			"hidden": 1,
			"print_hide": 1,
			"description": "Idempotency key for the mobile upload contract (erpocr_integration.fleet_api.upload_fleet_slip). Client-generated UUID; a DB UNIQUE constraint makes 3G retries race-safe — a duplicate upload returns the original slip instead of creating a second. NULL for Drive-sourced and Desk-created slips (nullable-unique: multiple NULLs coexist, so the Drive pipeline is unaffected). no_copy so a copy/amend starts fresh without colliding on the key. The DB index is the enforcement point, never an app-layer check."
		},
		{
			"fieldname": "tax_template",
			"fieldtype": "Link",
			"label": "Tax Template",
			"options": "Purchase Taxes and Charges Template"
		},
		{
			"fieldname": "section_break_vehicle",
			"fieldtype": "Section Break",
			"label": "Vehicle & Posting"
		},
		{
			"fieldname": "vehicle_registration",
			"fieldtype": "Data",
			"label": "Vehicle Registration",
			"description": "Number plate extracted from slip"
		},
		{
			"fieldname": "fleet_vehicle",
			"fieldtype": "Link",
			"label": "Fleet Vehicle",
			"options": "Fleet Vehicle",
			"ignore_user_permissions": 1,
			"description": "Matched from vehicle registration (requires fleet_management app)"
		},
		{
			"fieldname": "vehicle_match_status",
			"fieldtype": "Select",
			"label": "Vehicle Match Status",
			"options": "\nAuto Matched\nSuggested\nUnmatched\nConfirmed",
			"read_only": 1
		},
		{
			"fieldname": "column_break_vehicle",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "posting_mode",
			"fieldtype": "Select",
			"label": "Posting Mode",
			"options": "\nFleet Card\nDirect Expense",
			"description": "Auto-set from vehicle config: Fleet Card = control record (no PI; cost booked from provider invoice), Direct Expense = creates a Purchase Invoice. Editable — flip during review if a slip was actually paid on a different card."
		},
		{
			"fieldname": "fleet_card_supplier",
			"fieldtype": "Link",
			"label": "Supplier",
			"options": "Supplier",
			"description": "Fleet card provider (auto-set from vehicle) or default supplier from OCR Settings"
		},
		{
			"fieldname": "expense_account",
			"fieldtype": "Link",
			"label": "Expense / Control Account",
			"options": "Account",
			"description": "Control account for Fleet Card mode, expense account for Direct Expense mode"
		},
		{
			"fieldname": "cost_center",
			"fieldtype": "Link",
			"label": "Cost Center",
			"options": "Cost Center",
			"ignore_user_permissions": 1,
			"description": "Pulled from Fleet Vehicle config or manually set"
		},
		{
			"fieldname": "section_break_fuel",
